generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Language {
  id        Int               @id @default(autoincrement())
  code      String            @unique
  name      String
  direction String            @default("ltr")
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  books     BookTranslation[]

  @@map("languages")
}

model Book {
  id           Int               @id @default(autoincrement())
  slug         String            @unique
  coverUrl     String?
  fileUrl      String?
  externalUrl  String?
  featured     Boolean           @default(false)
  views        Int               @default(0)
  publishedAt  DateTime?
  authorId     Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  isbn         String?           @unique
  quantity     Int               @default(1)
  translations BookTranslation[]
  author       Author?           @relation(fields: [authorId], references: [id])
  borrowings   Borrowing[]
  categories   CategoryOnBook[]
  favorites    Favorite[]
  reservations Reservation[]

  @@map("books")
}

model BookTranslation {
  id          Int      @id @default(autoincrement())
  bookId      Int
  languageId  Int
  title       String
  description String?
  authorName  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  language    Language @relation(fields: [languageId], references: [id])

  @@unique([bookId, languageId])
  @@map("book_translations")
}

model Author {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  bio       String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  books     Book[]

  @@map("authors")
}

model Category {
  id    Int              @id @default(autoincrement())
  name  String
  slug  String           @unique
  icon  String?
  books CategoryOnBook[]

  @@map("categories")
}

model CategoryOnBook {
  bookId     Int
  categoryId Int
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([bookId, categoryId])
  @@map("category_on_books")
}

model User {
  id                Int            @id @default(autoincrement())
  name              String
  email             String         @unique
  password          String
  role              Role           @default(USER)
  preferredLanguage String         @default("en")
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  phone             String?
  borrowings        Borrowing[]
  favorites         Favorite[]
  notifications     Notification[]
  reservations      Reservation[]

  @@map("users")
}

model Borrowing {
  id                  Int             @id @default(autoincrement())
  bookId              Int
  userId              Int
  issueDate           DateTime        @default(now())
  dueDate             DateTime
  returnDate          DateTime?
  status              BorrowingStatus @default(ISSUED)
  fineAmount          Float           @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  dueDateReminderSent Boolean         @default(false)
  book                Book            @relation(fields: [bookId], references: [id])
  user                User            @relation(fields: [userId], references: [id])

  @@map("borrowings")
}

model Reservation {
  id        Int               @id @default(autoincrement())
  bookId    Int
  userId    Int
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  book      Book              @relation(fields: [bookId], references: [id])
  user      User              @relation(fields: [userId], references: [id])

  @@map("reservations")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Favorite {
  userId    Int
  bookId    Int
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, bookId])
  @@map("favorites")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

enum ReservationStatus {
  PENDING
  NOTIFIED
  COMPLETED
  CANCELLED
}

enum BorrowingStatus {
  ISSUED
  RETURNED
  OVERDUE
}

enum Role {
  USER
  ADMIN
}
